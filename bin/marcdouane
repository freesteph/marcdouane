#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "dry/cli"

module Marcdouane
  module CLI
    module Commands
      extend Dry::CLI::Registry

      class Version < Dry::CLI::Command
        desc "Print version"

        def call(*)
          puts Marcdouane::VERSION
        end
      end

      class Check < Dry::CLI::Command
        desc "Check the Markdown of one or more file"

        argument :files,
                 type: :array,
                 required: true,
                 desc: "Files to check against"

        def call(files: [], **)
          if files.empty?
            puts "No files provided."
            return
          end

          files.each do |file|
            puts "Checking `#{file}'..."

            if !File.exist?(file)
              $stderr.puts "`#{file}' is missing, or not a valid file."
              exit 1
            end

            puts "Done."
          end
        end
      end


      register "version", Version, aliases: ["v", "-v", "--version"]
      register "check", Check
    end
  end
end

Dry::CLI.new(Marcdouane::CLI::Commands).call
