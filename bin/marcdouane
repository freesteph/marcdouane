#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "dry/cli"
require "marcdouane"

# rubocop:disable Style/Documentation
module Marcdouane
  module CLI
    module Commands
      extend Dry::CLI::Registry

      class Version < Dry::CLI::Command
        desc "Print version"

        def call(*)
          puts Marcdouane::VERSION
        end
      end

      class Check < Dry::CLI::Command
        desc "Check the Markdown of one or more file"

        option :verbose,
               type: :boolean,
               default: false,
               desc: "Verbose output"

        option :config,
               type: :string,
               required: false,
               desc: "Configuration file"

        argument :files,
                 type: :array,
                 required: true,
                 desc: "Files to check against"

        option :"custom-rules",
               type: :string,
               required: false,
               desc: "Path to a file containing custom rules"

        def call(files: [], **options)
          check_files!(files)

          if options[:"custom-rules"]
            load options[:"custom-rules"]
          end

          files
            .map  { |file| Marcdouane::FileChecker.call(file, options) }
            .then { |codes| exit(codes.max) }
        end

        def check_files!(files)
          if files.empty?
            puts "No files provided."
            exit 0
          end

          files.each do |file|
            unless File.exist?(file)
              warn "`#{file}' is missing, or not a valid file."
              exit 1
            end
          end
        end
      end

      register "version", Version, aliases: ["v", "-v", "--version"]
      register "check", Check
    end
  end
end
# rubocop:enable Style/Documentation

Dry::CLI.new(Marcdouane::CLI::Commands).call
